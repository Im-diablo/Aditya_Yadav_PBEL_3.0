# AI-Powered Financial Fraud Detection System
# https://github.com/yourusername/fraud_detection_project

# ── Python ────────────────────────────────────────────────────
__pycache__/
*.py[cod]
*$py.class
*.pyo
*.pyd

# ── Virtual environments ──────────────────────────────────────
venv/
env/
.env
.venv/
ENV/

# ── Distribution / packaging ──────────────────────────────────
dist/
build/
*.egg-info/
*.egg

# ── Jupyter Notebooks ─────────────────────────────────────────
.ipynb_checkpoints/

# ── Data ──────────────────────────────────────────────────────
# Raw datasets — too large for Git, download via Kaggle CLI
data/raw/*.csv
data/raw/signatures/

# Keep processed splits (small CSV outputs)
!data/processed/*.csv

# ── Model weights ─────────────────────────────────────────────
# Binaries — store in model registry or HuggingFace Hub instead
models/
models/xgboost_fraud.pkl
models/scaler.pkl
models/siamese_resnet18.pt
models/distilbert_fraud/
models/distilbert_fraud/**

# ── OS / IDE ──────────────────────────────────────────────────
.DS_Store
Thumbs.db
.idea/
.vscode/
*.swp
*.swo
*.bak

# ── Kaggle credentials ────────────────────────────────────────
kaggle.json
.kaggle/

# ── Misc ──────────────────────────────────────────────────────
*.log
*.tmp

data/
retrain_ml.py